{
  "name": "dnsctl-nix",
  "private": true,
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/main.ts --target=bun --format=esm --outfile=dist/main.js --minify",
    "check": "bun run typecheck && bun run build",
    "sync:nix": "bunx bun2nix -o bun.nix",
    "start": "bun dist/main.js",
    "typecheck": "bunx tsc --noEmit"
  }
}
